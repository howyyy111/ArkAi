rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && (request.auth.uid == uid || request.auth.token.email == uid);
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /integrations/google_oauth {
        allow read, write: if false;
      }

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    match /browser_clients/{clientId} {
      allow read, write: if false;
    }

    match /chat_sessions/{sessionId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
