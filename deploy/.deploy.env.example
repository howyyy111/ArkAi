PROJECT_ID=your-gcp-project-id
# Optional. If omitted, the deploy script resolves it automatically with gcloud.
# PROJECT_NUMBER=123456789012
REGION=us-central1

FRONTEND_SERVICE_NAME=arkais-frontend
AGENT_SERVICE_NAME=ark-learning-agent
AUTH_SERVICE_NAME=auth-function

GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1
ALLOW_UNAUTHENTICATED=true

# Optional runtime service account shared by Cloud Run services.
# RUNTIME_SERVICE_ACCOUNT=your-service-account@your-project-id.iam.gserviceaccount.com

FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_APP_ID=your-firebase-web-app-id
# FIRESTORE_DATABASE=ark-ai
# FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Optional tuning.
# ARKAIS_AGENT_TIMEOUT_SECONDS=90
# ARKAIS_AGENT_WITH_UI=true
# Production uses Firestore-backed sessions by default and fails fast if they are unavailable.
# Only set this for local/debug use when you intentionally want in-memory sessions.
# ARKAIS_ALLOW_IN_MEMORY_SESSIONS=1
# Optional retention tuning.
# ARKAIS_BROWSER_CLIENT_RETENTION_DAYS=30
# ARKAIS_CHAT_SESSION_RETENTION_DAYS=90
# ARKAIS_CHAT_MESSAGE_RETENTION_DAYS=90
